                    for (let i = 0; i < 8; i++) {
                        let sy = yTop + 10 + Math.random() * (yBottom - yTop - 20);
                        ctxDischarge.beginPath();
                        ctxDischarge.moveTo(cathodeX + 10, sy);
                        let cpX = cathodeX + totalGap * 0.5;
                        let cpY = sy + (Math.random() - 0.5) * 20;
                        ctxDischarge.quadraticCurveTo(cpX, cpY, anodeX - 10, sy + (Math.random() - 0.5) * 10);
