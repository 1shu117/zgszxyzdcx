    <script>
        (function() {
            const modeDischargeBtn = document.getElementById('modeGlowDischargeBtn');
            const modeGlowballBtn = document.getElementById('modeGlowBallBtn');
            const dischargeModule = document.getElementById('dischargeModule');
            const glowballModule = document.getElementById('glowballModule');
            const globalTooltip = document.getElementById('globalTooltip');

            let glowVoltage = 80;
            let glowPressure = 50;
            let animationId = null;
            let mouseX = 200,
                mouseY = 200;
            let isMouseInside = false;
            let updateMouseHandler = null,
                leaveMouseHandler = null,
                touchMoveHandler = null,
                touchEndHandler = null;

            function switchToDischarge() {
                modeDischargeBtn.classList.add('active');
                modeGlowballBtn.classList.remove('active');
                dischargeModule.style.display = 'block';
                glowballModule.style.display = 'none';
                stopGlowAnimation();
                updateSimulation();
            }

            function switchToGlowball() {
