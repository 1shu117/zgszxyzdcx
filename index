                    ctxDischarge.restore();
                    ctxDischarge.fillStyle = '#2ecc71';
                    ctxDischarge.beginPath();
                    ctxDischarge.arc(cathodeX - 34, yTop - 4, 7, 0, Math.PI * 2);
                    ctxDischarge.fill();
                    ctxDischarge.shadowBlur = 12;
                    ctxDischarge.shadowColor = '#2ecc71';
                    ctxDischarge.fillStyle = '#fff';
                    ctxDischarge.beginPath();
                    ctxDischarge.arc(cathodeX - 34, yTop - 4, 3.5, 0, Math.PI * 2);
                    ctxDischarge.fill();
                    ctxDischarge.shadowBlur = 0;
                    ctxDischarge.font = 'bold 11px sans-serif';
                    ctxDischarge.fillStyle = '#2ecc71';
                    ctxDischarge.fillText('● 辉光管已点亮', cathodeX - 24, yTop - 2);
                } else {
                    ctxDischarge.fillStyle = '#e74c3c';
                    ctxDischarge.beginPath();
                    ctxDischarge.arc(cathodeX - 34, yTop - 4, 6, 0, Math.PI * 2);
                    ctxDischarge.fill();
                    ctxDischarge.font = '11px sans-serif';
                    ctxDischarge.fillStyle = '#e74c3c';
                    ctxDischarge.fillText('○ 未触发 (需≥' + Math.round(Vb) + 'V)', cathodeX - 24, yTop - 2);
                }
                setupRegionTooltip(cathodeX, totalGap, regions, yTop, yBottom);
            }

            function setupRegionTooltip(cathodeX, totalGap, regions, yTop, yBottom) {
                const canvas = dischargeCanvas;
                const onMouseMove = (e) => {
                    const rect = canvas.getBoundingClientRect();
                    const scaleX = canvas.width / rect.width;
                    const scaleY = canvas.height / rect.height;
                    let canvasX = (e.clientX - rect.left) * scaleX;
                    let canvasY = (e.clientY - rect.top) * scaleY;
                    if (canvasY < yTop || canvasY > yBottom) {
                        globalTooltip.style.opacity = '0';
                        return;
                    }
                    let posX = canvasX;
                    let startX = cathodeX;
                    let found = null;
                    for (let reg of regions) {
                        let endX = startX + reg.len;
                        if (posX >= startX && posX <= endX) { found = reg; break; }
                        startX = endX;
                    }
                    if (found && found.key && regionDescriptions[found.key]) {
                        globalTooltip.innerHTML =
                            `<strong>${found.label}</strong><br>${regionDescriptions[found.key]}`;
                        globalTooltip.style.left = (e.clientX + 15) + 'px';
                        globalTooltip.style.top = (e.clientY - 50) + 'px';
                        globalTooltip.style.opacity = '1';
                    } else {
                        globalTooltip.style.opacity = '0';
                    }
                };
                const onMouseLeave = () => { globalTooltip.style.opacity = '0'; };
                canvas.removeEventListener('mousemove', onMouseMove);
                canvas.removeEventListener('mouseleave', onMouseLeave);
                canvas.addEventListener('mousemove', onMouseMove);
                canvas.addEventListener('mouseleave', onMouseLeave);
            }

            function drawIVCurve(operU, operI, Vb, gasKey) {
                const w = ivCanvas.width,
                    h = ivCanvas.height;
                ctxIV.clearRect(0, 0, w, h);
                ctxIV.fillStyle = "#fdfaf3";
                ctxIV.fillRect(0, 0, w, h);

                const marginLeft = 105,
                    marginRight = 50,
                    marginTop = 50,
                    marginBottom = 60;
                const chartW = w - marginLeft - marginRight,
                    chartH = h - marginTop - marginBottom;
                // 横轴起点改为 -11，终点 5，以容纳 A 点 10⁻¹⁰ 并有合适边距
                const logMin = -11,
                    logMax = 5;
                const gas = gasParams[gasKey];
                const Uc = gas ? gas.Uc : 150;
                const Vb_clamped = Math.min(1100, Math.max(80, Vb));
                const normalGlowVoltage = Math.min(Uc, Vb_clamped * 0.7);

                // ★ 关键点定义 — 按照用户要求的电流值调整 logI
                const points = {
                    A: { logI: -10, U: 8, region: 'AB', label: 'A' },
                    B: { logI: -9, U: 25, region: 'BC', label: 'B' },
                    C: { logI: -8, U: 90, region: 'CD', label: 'C' },
                    D: { logI: -7, U: Math.min(Vb_clamped * 0.88, Vb_clamped - 18), region: 'DE', label: 'D' },
                    E: { logI: -5.5, U: Vb_clamped, region: 'EF', label: 'E' },
                    F: { logI: -5.5, U: normalGlowVoltage, region: 'FG', label: 'F' },
                    Fp: { logI: -4, U: normalGlowVoltage, region: 'FG', label: "F'" },
                    G: { logI: -2, U: normalGlowVoltage, region: 'FG', label: 'G' },
                    H: { logI: 0, U: Math.min(normalGlowVoltage + 90, Vb_clamped + 70), region: 'GH', label: 'H' },
                    I: { logI: 1.3, U: Math.max(80, normalGlowVoltage * 0.55), region: 'HI', label: 'I' },
                    J: { logI: 2, U: 28, region: 'IJ', label: 'J' },
                    K: { logI: 4, U: 38, region: 'JK', label: 'K' }
                };
                if (points.D.U <= points.C.U) points.D.U = points.C.U + 15;
                if (points.E.U <= points.D.U) points.E.U = points.D.U + 25;
                if (points.F.U >= points.E.U) points.F.U = points.E.U - 30;
                if (points.F.U < 55) points.F.U = 55;
                if (points.Fp.U !== points.F.U) points.Fp.U = points.F.U;
                if (points.G.U !== points.F.U) points.G.U = points.F.U;

                // 动态电压轴：取所有关键点及工作点中最大电压的120%
                let maxVoltageOnCurve = Math.max(
                    points.D.U, points.E.U, points.H.U, operU, 200
                );
                let dynamicMaxU = Math.ceil(maxVoltageOnCurve * 1.2 / 20) * 20;
                dynamicMaxU = Math.min(1200, Math.max(300, dynamicMaxU));

                const operLogI = Math.log10(Math.max(1e-13, operI));
                // 根据新的 logI 范围判断工作点所处区域
                let activeRegion = '';
                if (operLogI < -9) activeRegion = 'AB';
                else if (operLogI < -8) activeRegion = 'BC';
                else if (operLogI < -6) activeRegion = 'CD';
                else if (operLogI < -5) activeRegion = 'DE';
                else if (operLogI < -4 && operU >= Vb_clamped) activeRegion = 'EF';
                else if (operLogI < 0 && operU < Vb_clamped * 1.3) activeRegion = 'FG';
                else if (operLogI < 1 && operU > normalGlowVoltage + 20) activeRegion = 'GH';
                else if (operLogI < 2 && operU < normalGlowVoltage) activeRegion = 'HI';
                else if (operLogI < 3) activeRegion = 'IJ';
                else activeRegion = 'JK';

                function getPixel(p) {
                    let x = marginLeft + ((p.logI - logMin) / (logMax - logMin)) * chartW;
                    let y = h - marginBottom - (p.U / dynamicMaxU) * chartH;
                    return { x, y };
                }
                const pix = {};
                for (let key in points) pix[key] = getPixel(points[key]);

                function drawCurveSeg(from, to, color = "#2c6e9e", width = 2.8, dashed = false, region = '') {
                    const isActive = (region === activeRegion);
                    ctxIV.beginPath();
                    ctxIV.moveTo(from.x, from.y);
                    ctxIV.lineTo(to.x, to.y);
                    ctxIV.setLineDash(dashed ? [8, 5] : []);
                    ctxIV.strokeStyle = isActive ? '#e74c3c' : color;
                    ctxIV.lineWidth = isActive ? width + 2 : width;
                    ctxIV.stroke();
                    ctxIV.setLineDash([]);
                }

                // 背景区域色块（按 logI 划分，更新范围）
                const regionRanges = [
                    { name: '暗放电区', start: -10, end: -5.5, color: '#34495e' },
                    { name: '辉光放电区', start: -5.5, end: 0, color: '#9b59b6' },
                    { name: '电弧放电区', start: 0, end: 4, color: '#e74c3c' }
                ];
                regionRanges.forEach(r => {
                    let x1 = marginLeft + ((r.start - logMin) / (logMax - logMin)) * chartW;
                    let x2 = marginLeft + ((r.end - logMin) / (logMax - logMin)) * chartW;
                    ctxIV.fillStyle = r.color + '18';
                    ctxIV.fillRect(x1, marginTop, x2 - x1, chartH);
                    ctxIV.fillStyle = r.color;
                    ctxIV.fillRect(x1 + 4, marginTop - 34, Math.min(100, x2 - x1 - 8), 22);
                    ctxIV.fillStyle = '#fff';
                    ctxIV.font = 'bold 11px "PingFang SC","Segoe UI",sans-serif';
                    ctxIV.fillText(r.name, x1 + 8, marginTop - 18);
                });

                // 坐标轴
                ctxIV.beginPath();
                ctxIV.strokeStyle = "#444";
                ctxIV.lineWidth = 1.8;
                ctxIV.moveTo(marginLeft, h - marginBottom);
                ctxIV.lineTo(w - marginRight, h - marginBottom);
                ctxIV.moveTo(marginLeft, marginTop);
                ctxIV.lineTo(marginLeft, h - marginBottom);
                ctxIV.stroke();

                // 横轴标签 (logI)，从 -11 到 5，每 2 个单位标注
                ctxIV.font = "10px sans-serif";
                ctxIV.fillStyle = "#5a7a9e";
                for (let li = -11; li <= 5; li += 2) {
                    let x = marginLeft + ((li - logMin) / (logMax - logMin)) * chartW;
                    if (x >= marginLeft && x <= w - marginRight) {
                        ctxIV.beginPath();
                        ctxIV.moveTo(x, h - marginBottom);
                        ctxIV.lineTo(x, h - marginBottom + 6);
                        ctxIV.stroke();
                        ctxIV.fillText("10^" + li, x - 16, h - marginBottom + 18);
                    }
                }
                // 纵轴标签
                ctxIV.fillStyle = "#5a7a9e";
                const uStep = dynamicMaxU <= 400 ? 50 : (dynamicMaxU <= 600 ? 100 : 150);
                for (let u = 0; u <= dynamicMaxU; u += uStep) {
                    let y = h - marginBottom - (u / dynamicMaxU) * chartH;
                    ctxIV.beginPath();
                    ctxIV.moveTo(marginLeft - 6, y);
                    ctxIV.lineTo(marginLeft, y);
                    ctxIV.stroke();
                    ctxIV.fillText(u, marginLeft - 36, y + 4);
                }
                ctxIV.fillStyle = "#3a5a7e";
                ctxIV.font = "bold 11px sans-serif";
                ctxIV.fillText("电压 (V)", marginLeft - 50, marginTop - 18);
                ctxIV.fillText("电流 log₁₀(I/A)", w - marginRight - 30, h - marginBottom + 30);

                // 绘制曲线段
                drawCurveSeg(pix.A, pix.B, "#2c6e9e", 2.8, false, 'AB');
                drawCurveSeg(pix.B, pix.C, "#2c6e9e", 2.8, false, 'BC');   // B 和 C 同 logI，垂直段
                drawCurveSeg(pix.C, pix.D, "#2c6e9e", 2.8, false, 'CD');
                drawCurveSeg(pix.D, pix.E, "#9b59b6", 2.8, false, 'DE');
                drawCurveSeg(pix.E, pix.F, "#d97706", 2.5, true, 'EF');   // 击穿过渡虚线
                drawCurveSeg(pix.D, pix.F, "#9b59b6", 2.8, false, 'DF');
                drawCurveSeg(pix.F, pix.Fp, "#9b59b6", 3.2, false, 'FG');
                drawCurveSeg(pix.Fp, pix.G, "#9b59b6", 3.2, false, 'FG');
                drawCurveSeg(pix.G, pix.H, "#9b59b6", 2.8, false, 'GH');
                drawCurveSeg(pix.H, pix.I, "#d97706", 2.5, true, 'HI');
                drawCurveSeg(pix.I, pix.J, "#e74c3c", 2.8, false, 'IJ');
                drawCurveSeg(pix.J, pix.K, "#e74c3c", 2.8, false, 'JK');

                // 绘制关键点
                for (let key in points) {
                    let p = pix[key];
                    let lbl = points[key].label;
                    let reg = points[key].region;
                    let isActive = (reg === activeRegion);
                    ctxIV.beginPath();
                    ctxIV.fillStyle = isActive ? '#e74c3c' : '#c0392b';
                    ctxIV.arc(p.x, p.y, isActive ? 8 : 6, 0, Math.PI * 2);
                    ctxIV.fill();
                    ctxIV.fillStyle = '#fff';
                    ctxIV.beginPath();
                    ctxIV.arc(p.x, p.y, 2.5, 0, Math.PI * 2);
                    ctxIV.fill();
                    ctxIV.fillStyle = '#7a2020';
                    ctxIV.font = 'bold 11px sans-serif';
                    ctxIV.fillText(lbl, p.x - 7, p.y - 11);
                }

                // 区域标注
                const regionLabels = [
                    { x: (pix.A.x + pix.B.x) / 2, y: pix.A.y - 14, text: "本底电离", reg: 'AB' },
                    { x: (pix.B.x + pix.C.x) / 2, y: pix.C.y + 20, text: "饱和区", reg: 'BC' },
                    { x: (pix.C.x + pix.D.x) / 2, y: pix.D.y - 14, text: "汤生放电", reg: 'CD' },
                    { x: (pix.F.x + pix.G.x) / 2, y: pix.F.y - 14, text: "正常辉光", reg: 'FG' },
                    { x: (pix.G.x + pix.H.x) / 2, y: pix.H.y - 14, text: "异常辉光", reg: 'GH' },
                    { x: (pix.I.x + pix.J.x) / 2, y: pix.I.y - 14, text: "非热电弧", reg: 'IJ' },
                    { x: (pix.J.x + pix.K.x) / 2, y: pix.K.y + 18, text: "热电弧", reg: 'JK' }
                ];
                ctxIV.font = 'italic 10px sans-serif';
                regionLabels.forEach(lbl => {
                    ctxIV.fillStyle = lbl.reg === activeRegion ? '#e74c3c' : '#5a7a9e';
                    ctxIV.fillText(lbl.text, lbl.x - 20, lbl.y);
                });

                // 击穿电压虚线
                let yVb = h - marginBottom - (Vb_clamped / dynamicMaxU) * chartH;
                ctxIV.beginPath();
                ctxIV.setLineDash([5, 4]);
                ctxIV.strokeStyle = "#e67e22";
                ctxIV.lineWidth = 2.2;
                ctxIV.moveTo(marginLeft, yVb);
                ctxIV.lineTo(w - marginRight, yVb);
                ctxIV.stroke();
                ctxIV.fillStyle = "#e67e22";
                ctxIV.font = "bold 10px sans-serif";
                ctxIV.fillText(`击穿电压 ${Math.round(Vb_clamped)}V`, marginLeft + 8, yVb - 5);
                // 阴极位降虚线
                let yUc = h - marginBottom - (Uc / dynamicMaxU) * chartH;
                ctxIV.beginPath();
                ctxIV.setLineDash([3, 4]);
                ctxIV.strokeStyle = "#2c9e6e";
                ctxIV.lineWidth = 1.6;
                ctxIV.moveTo(marginLeft, yUc);
                ctxIV.lineTo(w - marginRight, yUc);
                ctxIV.stroke();
                ctxIV.fillStyle = "#2c9e6e";
                ctxIV.font = "italic 9px sans-serif";
                ctxIV.fillText(`阴极位降 ${Uc}V`, marginLeft + 8, yUc - 4);
                ctxIV.setLineDash([]);

                ctxIV.fillStyle = "#7a8fa0";
                ctxIV.font = "italic 9px sans-serif";
                ctxIV.fillText(`纵轴范围: 0–${dynamicMaxU}V (最大电压×120%)`, w - marginRight - 180, marginTop - 30);

                setupIVTooltip(marginLeft, marginTop, chartW, chartH, h - marginBottom, logMin, logMax, dynamicMaxU,
                    points, pix);
            }

            function setupIVTooltip(marginLeft, marginTop, chartW, chartH, chartBottom, logMin, logMax, maxU, points,
            pix) {
                const onMouseMove = (e) => {
                    const rect = ivCanvas.getBoundingClientRect();
                    const scaleX = ivCanvas.width / rect.width;
                    const scaleY = ivCanvas.height / rect.height;
                    let canvasX = (e.clientX - rect.left) * scaleX;
                    let canvasY = (e.clientY - rect.top) * scaleY;
                    if (canvasX < marginLeft || canvasX > marginLeft + chartW ||
                        canvasY < marginTop || canvasY > chartBottom) {
                        globalTooltip.style.opacity = '0';
                        return;
                    }
                    let logI = logMin + ((canvasX - marginLeft) / chartW) * (logMax - logMin);
                    let region = '';
                    if (logI < points.B.logI) region = 'AB';
                    else if (logI < points.C.logI) region = 'BC';
                    else if (logI < points.D.logI) region = 'CD';
                    else if (logI < points.E.logI) region = 'DE';
                    else if (logI < points.F.logI) region = 'EF';
                    else if (logI < points.G.logI) region = 'FG';
                    else if (logI < points.H.logI) region = 'GH';
                    else if (logI < points.I.logI) region = 'HI';
                    else if (logI < points.J.logI) region = 'IJ';
                    else region = 'JK';
                    if (region && ivRegionDescriptions[region]) {
                        let desc = ivRegionDescriptions[region];
                        globalTooltip.innerHTML =
                            `<strong style="color:#ffaa44;">${desc.name}</strong><br>${desc.desc}`;
                        globalTooltip.style.left = (e.clientX + 15) + 'px';
                        globalTooltip.style.top = (e.clientY - 70) + 'px';
                        globalTooltip.style.opacity = '1';
                    } else {
                        globalTooltip.style.opacity = '0';
                    }
                };
                const onMouseLeave = () => { globalTooltip.style.opacity = '0'; };
                ivCanvas.removeEventListener('mousemove', onMouseMove);
                ivCanvas.removeEventListener('mouseleave', onMouseLeave);
                ivCanvas.addEventListener('mousemove', onMouseMove);
                ivCanvas.addEventListener('mouseleave', onMouseLeave);
            }

            function updateSimulation() {
                currentVoltage = parseFloat(voltageSlider.value);
                currentPressure = parseFloat(pressureSlider.value);
                currentDistance = parseFloat(distanceSlider.value);
                currentArea = parseFloat(areaSlider.value);
                currentGas = gasSelect.value;
                if (!isSyncing) {
                    voltageInput.value = Math.round(currentVoltage);
                    pressureInput.value = currentPressure;
                    distanceInput.value = currentDistance.toFixed(1);
                    areaInput.value = currentArea;
                }
                const gas = gasParams[currentGas];
                if (gas) {
                    document.getElementById('paramA').innerText = gas.A.toFixed(1);
                    document.getElementById('paramB').innerText = gas.B.toFixed(0);
                    document.getElementById('paramGamma').innerText = gas.gamma.toFixed(2);
                    const p_Torr = currentPressure * 0.00750062;
                    const d_cm = currentDistance / 10.0;
                    document.getElementById('pdValue').innerText = (p_Torr * d_cm).toFixed(4);
                }
                let Vb = calculatePaschenBreakdown(currentPressure, currentDistance, currentGas);
                cachedVb = Vb;
                const VbDisplay = Vb > 2500 ? ">2500" : Math.round(Vb);
                paschenVspan.innerText = VbDisplay;
                paschenVinline.innerText = VbDisplay;
                let current_A = calculateCurrent(currentVoltage, Vb, currentArea);
                let currentDensity = current_A / Math.max(0.01, currentArea);
                simCurrentSpan.innerText = current_A.toExponential(1);
                currentDensitySpan.innerText = currentDensity.toExponential(1);
                const logI = Math.log10(Math.max(1e-13, current_A));
                let stateText = "";
                if (logI < -8) stateText = "🟤 暗放电 (本底电离区 A→B)";
                else if (logI < -6) stateText = "🟠 暗放电 (饱和区 B→C)";
                else if (logI < -5.2) stateText = "🔴 暗放电 (汤生放电区 C→D)";
                else if (currentVoltage >= Vb && logI < -3) stateText = "🟣 击穿过渡区 (E→F)";
                else if (logI < -2 && currentVoltage < Vb * 1.3) stateText = "🟡 正常辉光放电区 (F→G)";
                else if (logI < 0) stateText = "🟢 异常辉光放电区 (G→H)";
                else if (logI < 1.5) stateText = "🔶 辉光→电弧过渡 (H→I)";
                else if (logI < 2.5) stateText = "🔵 非热电弧区 (I→J)";
                else stateText = "🔥 热电弧区 (J→K)";
                dischargeStateSpan.innerText = stateText;
                drawDischargeRegions(currentVoltage, Vb, current_A, currentPressure, currentDistance);
                drawIVCurve(currentVoltage, current_A, Vb, currentGas);
            }

            function onSliderChange() {
                if (isSyncing) return;
                isSyncing = true;
                updateSimulation();
                isSyncing = false;
            }

            function onInputChange(sourceSlider, sourceInput, minVal, maxVal, decimals) {
                if (isSyncing) return;
                isSyncing = true;
                let val = parseFloat(sourceInput.value);
                if (isNaN(val)) val = parseFloat(sourceSlider.value);
                val = Math.min(maxVal, Math.max(minVal, val));
                sourceInput.value = decimals > 0 ? val.toFixed(decimals) : Math.round(val);
                sourceSlider.value = val;
                updateSimulation();
                isSyncing = false;
            }

            voltageSlider.addEventListener('input', () => {
                voltageInput.value = voltageSlider.value;
                onSliderChange();
            });
            voltageInput.addEventListener('change', () => onInputChange(voltageSlider, voltageInput, 5, 1200, 0));
            voltageInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') voltageInput.blur(); });
            pressureSlider.addEventListener('input', () => {
                pressureInput.value = pressureSlider.value;
                onSliderChange();
            });
            pressureInput.addEventListener('change', () => onInputChange(pressureSlider, pressureInput, 1, 800, 1));
            pressureInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') pressureInput.blur(); });
            distanceSlider.addEventListener('input', () => {
                distanceInput.value = parseFloat(distanceSlider.value).toFixed(1);
                onSliderChange();
            });
            distanceInput.addEventListener('change', () => onInputChange(distanceSlider, distanceInput, 0.5, 60, 1));
            distanceInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') distanceInput.blur(); });
            areaSlider.addEventListener('input', () => {
                areaInput.value = areaSlider.value;
                onSliderChange();
            });
            areaInput.addEventListener('change', () => onInputChange(areaSlider, areaInput, 0.5, 100, 1));
            areaInput.addEventListener('keydown', (e) => { if (e.key === 'Enter') areaInput.blur(); });
            gasSelect.addEventListener('change', updateSimulation);
            resetBtn.addEventListener('click', () => {
                setAllParams(400, 100, 5.0, 10, 'ar');
            });
            presetStandardBtn.addEventListener('click', () => {
                setAllParams(270, 13.3, 50.0, 10, 'ar');
            });
            presetNeonBtn.addEventListener('click', () => {
                setAllParams(180, 200, 3.0, 5, 'ne');
            });

            function setAllParams(voltage, pressure, distance, area, gasKey) {
                isSyncing = true;
                voltageSlider.value = voltage;
                voltageInput.value = Math.round(voltage);
                pressureSlider.value = pressure;
                pressureInput.value = pressure;
                distanceSlider.value = distance;
                distanceInput.value = distance.toFixed(1);
                areaSlider.value = area;
                areaInput.value = area;
                gasSelect.value = gasKey;
                isSyncing = false;
                updateSimulation();
            }

            function initDischargeSimulation() {
                setAllParams(400, 100, 5.0, 10, 'ar');
            }

            window.addEventListener('load', () => {
                initDischargeSimulation();
                initGlowballControls();
                if (glowCanvas) { resizeGlowCanvas();
                    drawGlowball(); }
                switchToDischarge();
            });
            window.addEventListener('beforeunload', () => {
                stopGlowAnimation();
            });
            console.log('✅ 辉光放电仿真已更新：横轴调整为A=10⁻¹⁰，B/C=10⁻⁹，D=10⁻⁷，F=10⁻⁵·⁵，F\'=10⁻⁴，G=10⁻²，H=1，I≈20，J=100，K=10⁴');
        })();
    </script>
</body>
</html>
