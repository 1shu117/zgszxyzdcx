            function calculatePaschenBreakdown(p_Pa, d_mm, gasKey) {
                const gas = gasParams[gasKey];
                if (!gas) return 9999;
                const p_Torr = p_Pa * 0.00750062;
                const d_cm = d_mm / 10.0;
                const pd = p_Torr * d_cm;
                if (pd <= 1e-8) return 9999;
                const A = gas.A,
                    B = gas.B,
                    gamma = gas.gamma;
                const lnArg = A * pd;
                if (lnArg <= 1e-8) return 9999;
                const innerLog = Math.log(1 + 1 / gamma);
                if (innerLog <= 0) return 9999;
                const denominator = Math.log(lnArg) - Math.log(innerLog);
                if (denominator <= 1e-8) return 9999;
                let Vb = (B * pd) / denominator;
                Vb = Math.min(Vb, 3000);
                return Vb > 0 ? Vb : 9999;
            }

            function calculateCurrent(U, Vb, area) {
                let logI;
                if (U < Vb * 0.3) {
                    logI = -12 + (U / (Vb * 0.3)) * 3;
                } else if (U < Vb * 0.7) {
                    logI = -9 + ((U - Vb * 0.3) / (Vb * 0.4)) * 3;
                } else if (U < Vb) {
                    logI = -6 + ((U - Vb * 0.7) / (Vb * 0.3)) * 0.8;
                } else if (U < Vb * 1.05) {
                    logI = -5.2 + ((U - Vb) / (Vb * 0.05)) * 1.2;
                } else if (U < Vb * 1.6) {
                    logI = -4 + ((U - Vb * 1.05) / (Vb * 0.55)) * 2;
                } else if (U < Vb * 2.0) {
                    logI = -2 + ((U - Vb * 1.6) / (Vb * 0.4)) * 2;
                } else if (U < Vb * 2.5) {
                    logI = 0 + ((U - Vb * 2.0) / (Vb * 0.5)) * 1;
                } else {
                    logI = 1 + ((U - Vb * 2.5) / (Vb * 1.5)) * 3;
                }
                logI = Math.min(5, Math.max(-12, logI));
                let baseCurrent = Math.pow(10, logI);
                return baseCurrent * (area / 10);
            }

            function getRegionIntensity(U, Vb, current, p_Pa, d_mm) {
                let breakdown = (U >= Vb);
                let cathode = breakdown ? 0.3 + 0.5 * Math.min(1, (U - Vb) / (Vb + 0.1)) : 0.08;
                cathode = Math.min(0.95, Math.max(0.1, cathode));
                let negativeGlow = breakdown ? 0.4 + 0.6 * Math.min(1, current / 10) : 0.05;
                negativeGlow = Math.min(0.9, negativeGlow);
                let positiveColumn = breakdown ? 0.2 + 0.5 * Math.min(1, current / 12) : 0.02;
                positiveColumn = Math.min(0.7, positiveColumn);
                return { cathode, negativeGlow, positiveColumn };
            }

