            function drawDischargeRegions(U, Vb, current, p, d_mm) {
                const w = dischargeCanvas.width,
                    h = dischargeCanvas.height;
                ctxDischarge.clearRect(0, 0, w, h);
                ctxDischarge.fillStyle = "#11161c";
                ctxDischarge.fillRect(0, 0, w, h);
                const minX = 65,
                    maxX = w - 65;
                const d_min = 0.5,
                    d_max = 60;
                let anodeX = minX + (d_mm - d_min) / (d_max - d_min) * (maxX - minX);
                anodeX = Math.min(maxX, Math.max(minX + 30, anodeX));
                const cathodeX = minX;
                const totalGap = anodeX - cathodeX;
                if (totalGap <= 5) return;
                const yTop = 30,
                    yBottom = h - 30;
                ctxDischarge.fillStyle = "#7a5a3a";
                ctxDischarge.fillRect(cathodeX - 15, yTop, 15, yBottom - yTop);
                ctxDischarge.fillStyle = "#9e7e5a";
                ctxDischarge.fillRect(anodeX, yTop, 15, yBottom - yTop);
                ctxDischarge.fillStyle = "#f5d5b0";
                ctxDischarge.font = "bold 12px 'Segoe UI','PingFang SC',sans-serif";
                ctxDischarge.textAlign = "center";
                ctxDischarge.fillText("阴极 (−)", cathodeX - 8, yTop - 10);
                ctxDischarge.fillText("阳极 (+)", anodeX + 8, yTop - 10);
                ctxDischarge.textAlign = "start";
                const intensity = getRegionIntensity(U, Vb, current, p, d_mm);
                const astonPct = 0.02,
                    cathodeGlowPct = 0.03,
                    crookesPct = 0.08,
                    negativeGlowPct = 0.22,
                    faradayPct = 0.12,
                    positivePct = 0.48,
                    anodePct = 0.05;
                let astonLen = totalGap * astonPct;
                let cathodeGlowLen = totalGap * cathodeGlowPct;
                let crookesLen = totalGap * crookesPct;
                let negativeLen = totalGap * negativeGlowPct;
                let faradayLen = totalGap * faradayPct;
                let positiveLen = totalGap * positivePct;
                let anodeLen = totalGap * anodePct;
                let sum = astonLen + cathodeGlowLen + crookesLen + negativeLen + faradayLen + positiveLen + anodeLen;
                let adjust = totalGap / sum;
                astonLen *= adjust;
                cathodeGlowLen *= adjust;
                crookesLen *= adjust;
                negativeLen *= adjust;
                faradayLen *= adjust;
                positiveLen *= adjust;
                anodeLen = totalGap - (astonLen + cathodeGlowLen + crookesLen + negativeLen + faradayLen +
                positiveLen);
                let x = cathodeX;
                const regions = [
                    { len: astonLen, color: `rgba(50,40,60,${intensity.cathode*0.8})`, label: "阿斯顿暗区",
                        key: "aston" },
                    { len: cathodeGlowLen, color: `rgba(180,160,100,${intensity.cathode*0.6})`, label: "阴极辉区",
                        key: "cathodeGlow" },
                    { len: crookesLen, color: `rgba(30,35,50,${intensity.cathode*0.7})`, label: "克鲁克斯暗区",
                        key: "crookes" },
                    { len: negativeLen, color: `rgba(100,180,255,${intensity.negativeGlow*0.95})`, label: "负辉区",
                        key: "negativeGlow" },
                    { len: faradayLen, color: `rgba(40,50,70,${intensity.negativeGlow*0.4})`, label: "法拉第暗区",
                        key: "faraday" },
                    { len: positiveLen, color: `rgba(255,140,80,${intensity.positiveColumn*0.7})`, label: "正柱区",
                        key: "positiveColumn" },
                    { len: anodeLen, color: `rgba(80,180,100,${intensity.positiveColumn*0.5})`, label: "阳极区",
                        key: "anodeGlow" }
                ];
                regions.forEach(region => {
                    ctxDischarge.fillStyle = region.color;
                    ctxDischarge.fillRect(x, yTop, region.len, yBottom - yTop);
                    x += region.len;
                });
                const isBreakdown = (U >= Vb);
                const glowIntensity = isBreakdown ? Math.min(1, (U - Vb + 50) / 100) : 0;
                if (isBreakdown) {
                    ctxDischarge.save();
                    ctxDischarge.globalCompositeOperation = 'screen';
                    const glowGrad = ctxDischarge.createLinearGradient(cathodeX, yTop, anodeX, yBottom);
                    glowGrad.addColorStop(0, `rgba(100,150,255,${0.1*glowIntensity})`);
                    glowGrad.addColorStop(0.3, `rgba(150,200,255,${0.2*glowIntensity})`);
                    glowGrad.addColorStop(0.7, `rgba(255,180,100,${0.15*glowIntensity})`);
                    glowGrad.addColorStop(1, `rgba(100,255,150,${0.1*glowIntensity})`);
                    ctxDischarge.fillStyle = glowGrad;
                    ctxDischarge.fillRect(cathodeX, yTop, totalGap, yBottom - yTop);
                    ctxDischarge.fillStyle = `rgba(255,240,180,${0.3+0.4*glowIntensity})`;
                    for (let i = 0; i < 55 + 35 * glowIntensity; i++) {
