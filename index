            function drawGlowball() {
                if (!glowCtx) return;
                const w = glowCanvas.width,
                    h = glowCanvas.height;
                const cx = w / 2,
                    cy = h / 2;
                const radius = w / 2 - 10;
                const grad = glowCtx.createRadialGradient(cx, cy, 5, cx, cy, radius);
                grad.addColorStop(0, '#0a1420');
                grad.addColorStop(0.6, '#1a2a3a');
                grad.addColorStop(1, '#2c445e');
                glowCtx.fillStyle = grad;
                glowCtx.fillRect(0, 0, w, h);
                glowCtx.save();
                glowCtx.shadowBlur = 0;
                glowCtx.beginPath();
                glowCtx.arc(cx, cy, radius, 0, Math.PI * 2);
                glowCtx.fillStyle = 'rgba(255,255,200,0.05)';
                glowCtx.fill();
                const numStrands = 28;
                const time = Date.now() / 150;
                const mouseVerticalPos = (cy - mouseY) / radius;
                const heatRisePeriod = 8;
                const heatRiseOffset = Math.sin(time / heatRisePeriod) * 0.5 + 0.5;
                const bendAmount = Math.abs(mouseVerticalPos) < 0.6 ? (1 - Math.abs(mouseVerticalPos)) * 0.4 : 0;
                for (let i = 0; i < numStrands; i++) {
                    let angleBase = (i / numStrands) * Math.PI * 2;
                    let startR = 8 + 2 * Math.sin(angleBase * 6 + time);
                    let startX = cx + startR * Math.cos(angleBase);
                    let startY = cy + startR * Math.sin(angleBase);
                    let endX, endY;
                    if (isMouseInside) {
                        let dx = mouseX - startX,
                            dy = mouseY - startY;
                        let dist = Math.hypot(dx, dy);
                        let extendRatio = (radius - startR) / Math.max(dist, 0.1);
                        endX = startX + dx * extendRatio;
                        endY = startY + dy * extendRatio;
                        endY -= bendAmount * (radius - startR) * heatRiseOffset;
                        let jitter = 0.05 * (1 - glowPressure / 100);
                        endX += (Math.random() - 0.5) * jitter * radius;
                        endY += (Math.random() - 0.5) * jitter * radius;
                    } else {
                        let endR = radius - 5;
                        endX = cx + endR * Math.cos(angleBase);
                        endY = cy + endR * Math.sin(angleBase);
                    }
                    let strandProgress = (time / heatRisePeriod + i / numStrands) % 1;
                    let isStrandBroken = strandProgress > 0.85;
                    let breakPointRatio = isStrandBroken ? (strandProgress - 0.85) / 0.15 : 1;
                    let displayEndX = startX + (endX - startX) * breakPointRatio;
                    let displayEndY = startY + (endY - startY) * breakPointRatio;
                    let hue = (260 + 40 * Math.sin(angleBase * 3 + time)) % 360;
                    let sat = 75 + 15 * Math.sin(angleBase * 2);
                    let light = 45 + 30 * Math.sin(angleBase * 4 + time * 2);
                    let color = `hsl(${hue}, ${sat}%, ${light}%)`;
                    let lineWidth = 0.8 + (glowPressure / 100) * 1.2;
                    lineWidth *= isStrandBroken ? Math.max(0.1, 1 - (strandProgress - 0.85) * 3) : 1;
                    lineWidth += 0.5 * Math.sin(angleBase * 6 + time);
                    lineWidth = Math.max(0.3, lineWidth);
                    glowCtx.beginPath();
                    glowCtx.moveTo(startX, startY);
                    if (isMouseInside) {
                        let midX = (startX + displayEndX) / 2 + (Math.random() - 0.5) * 10;
                        let midY = (startY + displayEndY) / 2;
                        if (Math.abs(mouseVerticalPos) < 0.6) midY -= bendAmount * (radius - startR) * 0.5;
                        glowCtx.quadraticCurveTo(midX, midY, displayEndX, displayEndY);
                    } else {
                        glowCtx.lineTo(displayEndX, displayEndY);
                    }
                    glowCtx.lineWidth = lineWidth;
                    glowCtx.strokeStyle = color;
                    glowCtx.shadowBlur = 8 + glowVoltage / 100 * 10;
                    glowCtx.shadowColor = color;
                    glowCtx.stroke();
                    if (glowVoltage > 50 && !isStrandBroken && Math.random() > 0.65) {
                        let branchRatio = 0.35 + Math.random() * 0.3;
                        let branchStartX = startX + (displayEndX - startX) * branchRatio;
                        let branchStartY = startY + (displayEndY - startY) * branchRatio;
                        let mainAngle = Math.atan2(displayEndY - startY, displayEndX - startX);
                        let branchAngle = mainAngle + (Math.random() - 0.5) * 0.8;
                        let branchLength = (1 - branchRatio) * Math.hypot(displayEndX - startX, displayEndY -
                            startY);
                        let branchEndX = branchStartX + branchLength * Math.cos(branchAngle);
                        let branchEndY = branchStartY + branchLength * Math.sin(branchAngle);
                        branchEndY -= bendAmount * branchLength * 0.3;
                        glowCtx.beginPath();
                        glowCtx.moveTo(branchStartX, branchStartY);
                        glowCtx.lineTo(branchEndX, branchEndY);
                        glowCtx.lineWidth = lineWidth * 0.5;
                        glowCtx.strokeStyle = `hsl(${(hue + 30) % 360}, ${sat}%, ${light + 10}%)`;
                        glowCtx.shadowBlur = 5;
                        glowCtx.stroke();
                    }
                }
                glowCtx.shadowBlur = 15;
                glowCtx.shadowColor = 'rgba(255, 200, 100, 0.8)';
                glowCtx.beginPath();
                glowCtx.arc(cx, cy, 8 + glowVoltage / 50, 0, Math.PI * 2);
                glowCtx.fillStyle = '#ffaa66';
                glowCtx.fill();
                glowCtx.shadowBlur = 0;
                glowCtx.beginPath();
                glowCtx.arc(cx, cy, 4, 0, Math.PI * 2);
                glowCtx.fillStyle = 'white';
                glowCtx.fill();
                glowCtx.beginPath();
                glowCtx.arc(cx - 12, cy - 12, 12, 0, Math.PI * 2);
                glowCtx.fillStyle = 'rgba(255,255,255,0.2)';
                glowCtx.fill();
                glowCtx.restore();
            }

            function animateGlowball() {
                if (!glowballModule || glowballModule.style.display === 'none') return;
