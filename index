            function cleanupGlowEvents() {
                if (updateMouseHandler && glowCanvas) {
                    glowCanvas.removeEventListener('mousemove', updateMouseHandler);
                    glowCanvas.removeEventListener('mouseleave', leaveMouseHandler);
                    glowCanvas.removeEventListener('touchmove', touchMoveHandler);
                    glowCanvas.removeEventListener('touchend', touchEndHandler);
                }
            }

            function initGlowballAnimation() {
                cleanupGlowEvents();
                if (animationId) cancelAnimationFrame(animationId);
                resizeGlowCanvas();
                updateMouseHandler = (e) => {
                    const rect = glowCanvas.getBoundingClientRect();
                    const scaleX = glowCanvas.width / rect.width,
                        scaleY = glowCanvas.height / rect.height;
                    let canvasX = (e.clientX - rect.left) * scaleX;
                    let canvasY = (e.clientY - rect.top) * scaleY;
                    canvasX = Math.min(glowCanvas.width - 5, Math.max(5, canvasX));
                    canvasY = Math.min(glowCanvas.height - 5, Math.max(5, canvasY));
                    mouseX = canvasX;
                    mouseY = canvasY;
                    isMouseInside = true;
                };
                leaveMouseHandler = () => {
                    isMouseInside = false;
                    mouseX = glowCanvas.width / 2;
                    mouseY = glowCanvas.height / 2;
                };
                touchMoveHandler = (e) => {
                    e.preventDefault();
                    const touch = e.touches[0];
                    const rect = glowCanvas.getBoundingClientRect();
                    const scaleX = glowCanvas.width / rect.width,
                        scaleY = glowCanvas.height / rect.height;
                    let canvasX = (touch.clientX - rect.left) * scaleX;
                    let canvasY = (touch.clientY - rect.top) * scaleY;
                    canvasX = Math.min(glowCanvas.width - 5, Math.max(5, canvasX));
                    canvasY = Math.min(glowCanvas.height - 5, Math.max(5, canvasY));
                    mouseX = canvasX;
                    mouseY = canvasY;
                    isMouseInside = true;
                };
                touchEndHandler = () => {
                    isMouseInside = false;
                    mouseX = glowCanvas.width / 2;
                    mouseY = glowCanvas.height / 2;
                };
                glowCanvas.addEventListener('mousemove', updateMouseHandler);
                glowCanvas.addEventListener('mouseleave', leaveMouseHandler);
                glowCanvas.addEventListener('touchmove', touchMoveHandler);
                glowCanvas.addEventListener('touchend', touchEndHandler);
                animateGlowball();
            }

